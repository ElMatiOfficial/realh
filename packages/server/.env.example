# Server
PORT=3001
NODE_ENV=development
SERVER_BASE_URL=http://localhost:3001
CLIENT_BASE_URL=http://localhost:5173

# Optional: comma-separated list of allowed browser origins (CORS).
# If unset, CLIENT_BASE_URL is used. Never use "*" with credentialed requests.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Optional: JSON body size cap. Credentials are small; a tight cap limits abuse.
# JSON_BODY_LIMIT=256kb

# Mode (set to false to use real Firebase)
DEMO_MODE=true

# Firebase Admin (not needed in DEMO_MODE)
FIREBASE_PROJECT_ID=realh-poc
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Key management. "file" (default) reads/writes Ed25519 JWKs under packages/server/keys/.
# Production SHOULD use "kms" with a non-exportable key — see docs/SECURITY_ARCHITECTURE.md.
# KEY_MANAGER=file
# KMS_PROVIDER=gcp
# KMS_KEY_ID=
# KMS_KEY_KID=realh-key-1
